{
  "name": "enterprise-pos-erp",
  "version": "1.0.0",
  "description": "Enterprise-Grade POS & ERP Business Management Application",
  "main": "dist-vite/main/main.cjs",
  "author": "Enterprise Solutions",
  "license": "Commercial",
  "scripts": {
    "dev": "vite",
    "dev:main": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:vite && electron-builder",
    "build:vite": "vite build",
    "build:electron": "electron-builder --win --publish never",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.1",
    "date-fns": "^3.3.1",
    "electron-log": "^5.1.1",
    "electron-store": "^8.1.0",
    "framer-motion": "^11.0.5",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.8.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.2",
    "electron-builder": "^24.9.1",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.2",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.enterprise.pos",
    "productName": "Enterprise POS ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-vite/**/*",
      "node_modules/**/*",
      "package.json",
      "splash.html"
    ],
    "asar": false,
    "electronVersion": "28.2.2",
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "forceCodeSigning": false,
    "win": {
      "sign": false,
      "signingHashAlgorithms": [],
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": null,
      "installerLanguages": ["en_US"],
      "language": "1033"
    },
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ]
  }
}
